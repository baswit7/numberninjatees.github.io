{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numberninjatees.github.io/contracts/execution/rollback-plan.schema.json",
  "title": "Studio OS Rollback Plan",
  "description": "Readiness model for reversing a future action. This plan does not perform rollback.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "rollbackPlanId",
    "requestId",
    "reversible",
    "readiness",
    "preconditions",
    "rollbackSteps",
    "validationChecks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "rollbackPlanId": {
      "type": "string",
      "pattern": "^rollback-[a-z0-9-]{8,80}$"
    },
    "requestId": {
      "type": "string",
      "pattern": "^exec-req-[a-z0-9-]{8,80}$"
    },
    "reversible": {
      "type": "boolean"
    },
    "readiness": {
      "type": "string",
      "enum": [
        "ready",
        "partial",
        "missing",
        "not-reversible"
      ]
    },
    "preconditions": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 160
      }
    },
    "rollbackSteps": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 200
      }
    },
    "validationChecks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 160
      }
    }
  }
}
