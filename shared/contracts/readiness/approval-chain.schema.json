{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://numberninjatees.github.io/contracts/readiness/approval-chain.schema.json",
  "title": "Studio OS Approval Chain Readiness",
  "description": "Readiness model for approval-chain completeness. Approval metadata is never execution permission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "approvalChainId",
    "planId",
    "requestId",
    "requiredApprovers",
    "approvalRecords",
    "status",
    "approvalMetadataIsExecutionPermission",
    "reason",
    "checkedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "approvalChainId": { "type": "string", "pattern": "^approval-chain-[a-z0-9-]{8,80}$" },
    "planId": { "type": "string", "pattern": "^ready-plan-[a-z0-9-]{8,80}$" },
    "requestId": { "type": "string", "pattern": "^exec-req-[a-z0-9-]{8,80}$" },
    "requiredApprovers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "type": "string", "minLength": 2, "maxLength": 120 }
    },
    "approvalRecords": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "pattern": "^approval-[a-z0-9-]{8,80}$" }
    },
    "status": { "type": "string", "enum": ["complete", "incomplete", "denied", "expired", "blocked"] },
    "approvalMetadataIsExecutionPermission": { "type": "boolean", "const": false },
    "reason": { "type": "string", "minLength": 5, "maxLength": 500 },
    "checkedAt": { "type": "string", "format": "date-time" }
  }
}
